# InvParser — environment variables
# Copy to .env and fill in values.
# Startup validation: src/utils/envValidator.js (required vs optional).

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (MySQL) — all required at startup
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=invParserDb

# -----------------------------------------------------------------------------
# JWT — required at startup
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# -----------------------------------------------------------------------------
# Redis — required: set REDIS_URL (e.g. Railway) OR REDIS_HOST for local/Docker
# -----------------------------------------------------------------------------
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# OpenAI — required at startup (document parsing / classification)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your_openai_key_here

# -----------------------------------------------------------------------------
# Email — required: EMAIL_FROM + either BREVO_API_KEY or all SMTP_* below
# -----------------------------------------------------------------------------
BREVO_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# -----------------------------------------------------------------------------
# URLs — required at startup (use real HTTPS URLs in production, not localhost)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Google OAuth (optional — leave empty to disable)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT=http://localhost:5173/auth/google/success

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
# error | warn | info | debug — use debug in dev, info in production

CONSOLE_LOGS=true
# false in production to silence console (file logs still apply)

# -----------------------------------------------------------------------------
# File uploads (optional — default is backend/uploads relative to process cwd)
# -----------------------------------------------------------------------------
# UPLOAD_DIR=

# -----------------------------------------------------------------------------
# Database backup script (scripts/backup-database.js)
# -----------------------------------------------------------------------------
BACKUP_ALERT_EMAIL=admin@example.com
# Optional; if set, script can email on backup failure (uses Brevo or SMTP from above)

BACKUP_USE_DOCKER=true
# true = docker exec invparser_mysql mysqldump (default when unset)
# false = mysqldump on host using DB_HOST / DB_PORT

# AWS S3 (optional — backup upload / retention in backup script)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=invparser-backups
# AWS_REGION=eu-west-1
